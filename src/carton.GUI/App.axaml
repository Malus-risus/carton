<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="carton.App"
             xmlns:local="using:carton"
             xmlns:sty="using:FluentAvalonia.Styling"
             xmlns:vm="using:carton.ViewModels"
             RequestedThemeVariant="Default">

  <Application.DataTemplates>
    <local:ViewLocator/>
  </Application.DataTemplates>

  <Application.Resources>
    <local:ConnectionStatusConverter x:Key="ConnectionStatusConverter"/>
    <local:ResponsiveItemWidthConverter x:Key="ResponsiveItemWidthConverter"/>
    <local:LatencyForegroundConverter x:Key="LatencyForegroundConverter"/>
    <local:KernelDownloadMirrorDisplayConverter x:Key="KernelDownloadMirrorDisplayConverter"/>
    <local:KernelCacheCleanupPolicyDisplayConverter x:Key="KernelCacheCleanupPolicyDisplayConverter"/>
    <local:GitHubUpdateCheckStrategyDisplayConverter x:Key="GitHubUpdateCheckStrategyDisplayConverter"/>

    <DataTemplate x:Key="PageTemplate" DataType="vm:PageViewModelBase">
      <ContentControl Content="{Binding}"/>
    </DataTemplate>
  </Application.Resources>

  <Application.Styles>
    <sty:FluentAvaloniaTheme PreferSystemTheme="False"
                             PreferUserAccentColor="False"
                             CustomAccentColor="#FF0078D7"/>
    <StyleInclude Source="/Resources/CartonThemeResources.axaml" />

    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource CartonControlBackgroundChromeMediumBrush}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
    </Style>

    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,4,0,8"/>
    </Style>

    <Style Selector="Border.settingsItem">
      <Setter Property="Background" Value="{DynamicResource CartonSettingsItemBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CartonSettingsItemBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="MinHeight" Value="52"/>
    </Style>

    <Style Selector="Border.settingsItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource CartonSettingsItemPointerOverBackgroundBrush}"/>
    </Style>

    <Style Selector="Button.settingsItemLink">
      <Setter Property="Background" Value="{DynamicResource CartonSettingsItemBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CartonSettingsItemBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="MinHeight" Value="52"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>

    <Style Selector="Button.settingsItemLink:pointerover">
      <Setter Property="Background" Value="{DynamicResource CartonSettingsItemPointerOverBackgroundBrush}"/>
    </Style>

    <Style Selector="TextBlock.settingsTitle">
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.settingsDescription">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="Border.fluentBadge">
      <Setter Property="Background" Value="{DynamicResource CartonControlBackgroundBaseLowBrush}"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Padding" Value="6,2"/>
    </Style>

    <Style Selector="TextBlock.fluentBadgeText">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Foreground" Value="{DynamicResource CartonControlForegroundBaseMediumHighBrush}"/>
    </Style>

    <Style Selector="Border.toast">
      <Setter Property="Background" Value="#F2282E39"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="BoxShadow" Value="0 8 24 0 #22000000"/>
    </Style>

    <Style Selector="Border.toast TextBlock">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.accent">
      <Setter Property="Background" Value="{DynamicResource CartonAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CartonAccentBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource CartonAccentForegroundBrush}"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="16,6"/>
    </Style>

    <Style Selector="Button.accent:pointerover">
      <Setter Property="Background" Value="{DynamicResource CartonAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CartonAccentBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource CartonAccentForegroundBrush}"/>
      <Setter Property="Opacity" Value="0.92"/>
    </Style>

    <Style Selector="Button.accent:pressed">
      <Setter Property="Background" Value="{DynamicResource CartonAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CartonAccentBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource CartonAccentForegroundBrush}"/>
      <Setter Property="Opacity" Value="0.84"/>
    </Style>

    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="12,6"/>
    </Style>

    <Style Selector="TextBox">
      <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="TextBox.jsonConfigEditorInput">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="Transparent"/>
    </Style>

    <Style Selector="TextBox.jsonConfigEditorInput:pointerover">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="TextBox.jsonConfigEditorInput:focus">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="CornerRadius" Value="4"/>
    </Style>

  </Application.Styles>

</Application>
