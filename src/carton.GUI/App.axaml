<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="carton.App"
             xmlns:local="using:carton"
             xmlns:sty="using:FluentAvalonia.Styling"
             xmlns:vm="using:carton.ViewModels"
             RequestedThemeVariant="Default">

  <Application.DataTemplates>
    <local:ViewLocator/>
  </Application.DataTemplates>

  <Application.Resources>
    <local:ConnectionStatusConverter x:Key="ConnectionStatusConverter"/>
    <local:ResponsiveItemWidthConverter x:Key="ResponsiveItemWidthConverter"/>
    <local:LatencyForegroundConverter x:Key="LatencyForegroundConverter"/>
    <local:KernelDownloadMirrorDisplayConverter x:Key="KernelDownloadMirrorDisplayConverter"/>
    <local:KernelCacheCleanupPolicyDisplayConverter x:Key="KernelCacheCleanupPolicyDisplayConverter"/>

    <DataTemplate x:Key="PageTemplate" DataType="vm:PageViewModelBase">
      <ContentControl Content="{Binding}"/>
    </DataTemplate>
  </Application.Resources>

  <Application.Styles>
    <sty:FluentAvaloniaTheme PreferSystemTheme="False"
                             PreferUserAccentColor="False"/>
    <StyleInclude Source="/Resources/FluentAvaloniaLite.axaml" />

    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource CartonControlBackgroundChromeMediumBrush}"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
    </Style>

    <Style Selector="Border.toast">
      <Setter Property="Background" Value="#F2282E39"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="BoxShadow" Value="0 8 24 0 #22000000"/>
    </Style>

    <Style Selector="Border.toast TextBlock">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.accent">
      <Setter Property="Background" Value="{DynamicResource CartonAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CartonAccentBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource CartonAccentForegroundBrush}"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="16,6"/>
    </Style>

    <Style Selector="Button.accent:pointerover">
      <Setter Property="Background" Value="{DynamicResource CartonAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CartonAccentBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource CartonAccentForegroundBrush}"/>
      <Setter Property="Opacity" Value="0.92"/>
    </Style>

    <Style Selector="Button.accent:pressed">
      <Setter Property="Background" Value="{DynamicResource CartonAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CartonAccentBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource CartonAccentForegroundBrush}"/>
      <Setter Property="Opacity" Value="0.84"/>
    </Style>

    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="12,6"/>
    </Style>

    <Style Selector="TextBox">
      <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <Style Selector="TextBox.jsonConfigEditorInput">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="Transparent"/>
    </Style>

    <Style Selector="TextBox.jsonConfigEditorInput:pointerover">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="TextBox.jsonConfigEditorInput:focus">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="CornerRadius" Value="4"/>
    </Style>

  </Application.Styles>

</Application>
