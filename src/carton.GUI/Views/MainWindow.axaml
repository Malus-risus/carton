<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:carton.ViewModels"
        xmlns:views="using:carton.Views.Pages"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:carton.GUI.Models"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:uip="using:FluentAvalonia.UI.Controls.Primitives"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="620"
        x:Class="carton.Views.MainWindow"
        x:Name="MainWindowRoot"
        x:DataType="vm:MainViewModel"
        Title="{DynamicResource App.Name}"
        Width="910" Height="640"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="None">

  <Window.Styles>
    <Style Selector="Button.connectionToggle">
      <Setter Property="MinWidth" Value="56"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="ui|NavigationViewItem.navItem">
      <Setter Property="Height" Value="40"/>
      <Setter Property="Margin" Value="6,3"/>
    </Style>
    <Style Selector="ui|NavigationViewItem.navItem ui|IconSourceElement">
      <Setter Property="Width" Value="20"/>
      <Setter Property="Height" Value="20"/>
    </Style>
    <Style Selector="ui|NavigationViewItem.navItem /template/ uip|NavigationViewItemPresenter /template/ Border#SelectionIndicator">
      <Setter Property="IsVisible" Value="False"/>
    </Style>

  </Window.Styles>

  <Design.DataContext>
    <vm:MainViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0" Background="{DynamicResource CartonControlBackgroundChromeMediumBrush}">
      <Grid Margin="12,8">
        <TextBlock Grid.Column="0"
                   Text="{Binding DashboardViewModel.CurrentProfile}"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontSize="13"
                   TextTrimming="CharacterEllipsis"
                   MaxLines="1"
                   MaxWidth="220"
                   ToolTip.Tip="{Binding DashboardViewModel.CurrentProfile}"
                   Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
        <TextBlock
                   Text="{Binding CurrentPage.Title}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="14"
                   FontWeight="Medium"/>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <ui:NavigationView x:Name="RootNavigationView"
                         IsPaneOpen="True"
                         PaneDisplayMode="Left"
                         IsPaneToggleButtonVisible="False"
                         IsBackButtonVisible="False"
                         IsSettingsVisible="False"
                         AlwaysShowHeader="False"
                         OpenPaneLength="200"
                         CompactPaneLength="48"
                         MenuItemsSource="{Binding NavigationItems}"
                         Loaded="OnRootNavigationViewLoaded"
                         ItemInvoked="OnNavigationViewItemInvoked"
                         SelectionChanged="OnNavigationViewSelectionChanged">
        <ui:NavigationView.PaneHeader>
          <StackPanel Margin="0,28,0,24"
                      HorizontalAlignment="Center"
                      Spacing="12"
                      Width="168">
            <Image Width="52"
                   Height="52"
                   Source="/Assets/carton_icon.png"/>
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Center"
                        Margin="-10,0,0,0">
              <Ellipse Width="10"
                       Height="10"
                       Fill="{Binding IsConnected, Converter={StaticResource ConnectionStatusConverter}}"
                       VerticalAlignment="Center"/>
              <TextBlock Text="{Binding ConnectionStatus}"
                         FontSize="12"
                         VerticalAlignment="Center"
                         Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
            </StackPanel>

            <Button Command="{Binding DashboardViewModel.ToggleConnectionCommand}"
                    Classes="accent connectionToggle"
                    HorizontalAlignment="Center"
                    IsEnabled="{Binding DashboardViewModel.CanToggleConnection}"
                    ToolTip.Tip="{Binding DashboardViewModel.ConnectionToggleToolTip}">
              <Button.Transitions>
                <Transitions>
                  <DoubleTransition Property="MinWidth" Duration="0:0:0.2"/>
                </Transitions>
              </Button.Transitions>
              <Grid>
                <Grid Width="56"
                      Height="40"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      IsVisible="{Binding !DashboardViewModel.IsConnected}">
                  <Path Width="10"
                        Height="12"
                        Data="M0,0 L10,6 L0,12 Z"
                        Fill="#F8FFFFFF"
                        Stretch="Fill"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="2,0,0,0"/>
                </Grid>

                <StackPanel Orientation="Horizontal"
                            Spacing="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding DashboardViewModel.IsConnected}">
                  <Grid Width="40"
                        Height="40">
                    <Grid Width="12"
                          Height="12"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="4"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsVisible="{Binding DashboardViewModel.IsConnected}">
                      <Border Grid.Column="0"
                              Background="#F8FFFFFF"
                              CornerRadius="1"/>
                      <Border Grid.Column="1"
                              Background="#F8FFFFFF"
                              CornerRadius="1"/>
                    </Grid>
                  </Grid>
                  <Border Width="1"
                          Height="16"
                          Margin="0,12,0,12"
                          Background="#33FFFFFF"
                          IsVisible="{Binding DashboardViewModel.IsConnected}"/>
                  <Grid Margin="10,0,12,0"
                        VerticalAlignment="Center"
                        IsVisible="{Binding DashboardViewModel.IsConnected}">
                    <TextBlock Text="{Binding SessionStartTimeMeasureText}"
                               Opacity="0"
                               TextAlignment="Center"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="{DynamicResource CartonAccentForegroundBrush}"
                               IsHitTestVisible="False"/>
                    <TextBlock Text="{Binding SessionStartTimeText}"
                               TextAlignment="Center"
                               FontSize="13"
                               FontWeight="Bold"
                               FontFeatures="tnum"
                               Foreground="{DynamicResource CartonAccentForegroundBrush}"
                               IsHitTestVisible="False"/>
                  </Grid>
                </StackPanel>
              </Grid>
            </Button>
          </StackPanel>
        </ui:NavigationView.PaneHeader>

        <ui:NavigationView.MenuItemTemplate>
          <DataTemplate DataType="models:NavigationItem"
                        x:DataType="models:NavigationItem">
            <ui:NavigationViewItem Classes="navItem"
                                   Content="{Binding Title}"
                                   IconSource="{Binding IconSource}"
                                   Tag="{Binding Page}"/>
          </DataTemplate>
        </ui:NavigationView.MenuItemTemplate>
        <ui:NavigationView.Content>
          <Grid Background="{DynamicResource CartonWindowBackgroundBrush}">
          <views:DashboardView DataContext="{Binding DashboardViewModel}"
                               IsVisible="{Binding #MainWindowRoot.DataContext.IsDashboardPage}"/>
          <views:GroupsView DataContext="{Binding ActiveGroupsViewModel}"
                            IsVisible="{Binding #MainWindowRoot.DataContext.IsGroupsPage}"/>
          <ContentControl Content="{Binding ActiveTransientPage}"
                          IsVisible="{Binding #MainWindowRoot.DataContext.IsTransientPage}"/>
          <Grid IsHitTestVisible="False">
            <ItemsControl ItemsSource="{Binding #MainWindowRoot.DataContext.Toasts}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Bottom"
                          Margin="0,0,0,24">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="10"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:ToastNotificationViewModel">
                  <Border Classes="toast"
                          MaxWidth="440"
                          Opacity="{Binding Opacity}"
                          Margin="{Binding OffsetMargin}">
                    <Border.Transitions>
                      <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
                        <ThicknessTransition Property="Margin" Duration="0:0:0.22"/>
                      </Transitions>
                    </Border.Transitions>
                    <TextBlock Text="{Binding Message}"
                               TextWrapping="Wrap"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
          </Grid>
        </ui:NavigationView.Content>
      </ui:NavigationView>

      <Border x:Name="NavigationSelectionRail"
              Width="3"
              Height="18"
              Margin="10,0,0,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Background="#0078D4"
              CornerRadius="2"
              IsHitTestVisible="False"
              Opacity="1"
              IsVisible="False"
              ZIndex="100">
        <Border.Transitions>
          <Transitions>
            <ThicknessTransition Property="Margin" Duration="0:0:0.18"/>
            <DoubleTransition Property="Height" Duration="0:0:0.18"/>
          </Transitions>
        </Border.Transitions>
      </Border>
    </Grid>

    <ContentControl Grid.Row="0"
                    Grid.RowSpan="2"
                    Content="{Binding KernelDialogHost}">
      <ContentControl.ContentTemplate>
        <DataTemplate DataType="vm:MainViewModel">
          <Grid Background="#80000000">
            <Border Background="{DynamicResource CartonControlBackgroundChromeMediumBrush}"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="400"
                    MaxWidth="560">
              <StackPanel Spacing="16">
                  <TextBlock Text="{DynamicResource MainWindow.KernelDialog.Title}" FontSize="18" FontWeight="SemiBold"/>
                  <TextBlock TextWrapping="Wrap">
                    <Run Text="{DynamicResource MainWindow.KernelDialog.DescriptionLine1}"/>
                    <LineBreak/>
                    <Run Text="{DynamicResource MainWindow.KernelDialog.LatestVersionPrefix}"/>
                    <Run Text="{Binding LatestVersion}" FontWeight="Medium"/>
                  </TextBlock>

                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource Settings.Kernel.Mirror}"
                               VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding KernelDownloadMirrors}"
                              SelectedItem="{Binding SelectedKernelDownloadMirror}"
                              MinWidth="150"
                              IsEnabled="{Binding !IsDownloadingKernel}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Converter={StaticResource KernelDownloadMirrorDisplayConverter}}"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </Grid>

                  <ProgressBar IsIndeterminate="False"
                               Value="{Binding DownloadProgress}"
                               Maximum="100"
                               IsVisible="{Binding IsDownloadingKernel}"
                               Height="4"/>

                  <TextBlock Text="{Binding DownloadStatus}"
                             TextWrapping="Wrap"
                             FontSize="12"
                             Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>

                  <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="{Binding KernelPrimaryActionText}"
                            Command="{Binding DownloadKernelCommand}"
                            Classes="accent"
                            IsEnabled="{Binding !IsDownloadingKernel}"/>
                    <Button Content="{DynamicResource MainWindow.KernelDialog.Button.Later}"
                            Command="{Binding CloseKernelDialogCommand}"
                            IsEnabled="{Binding !IsDownloadingKernel}"/>
                  </StackPanel>
              </StackPanel>
            </Border>
          </Grid>
        </DataTemplate>
      </ContentControl.ContentTemplate>
    </ContentControl>

    <ContentControl Grid.Row="0"
                    Grid.RowSpan="2"
                    Content="{Binding AppUpdateDialogHost}">
      <ContentControl.ContentTemplate>
        <DataTemplate DataType="vm:AppUpdateCoordinator">
          <Grid Background="#80000000">
            <Border Background="{DynamicResource CartonControlBackgroundChromeMediumBrush}"
                    CornerRadius="8"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="400"
                    MaxWidth="560">
              <StackPanel Spacing="16">
                <TextBlock Text="{DynamicResource MainWindow.AppUpdateDialog.Title}" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock TextWrapping="Wrap">
                  <Run Text="{DynamicResource MainWindow.AppUpdateDialog.DescriptionLine1}"/>
                  <LineBreak/>
                  <Run Text="{DynamicResource MainWindow.AppUpdateDialog.LatestVersionPrefix}"/>
                  <Run Text="{Binding LatestAvailableVersion}" FontWeight="Medium"/>
                </TextBlock>

                <ProgressBar IsIndeterminate="False"
                             Value="{Binding AppUpdateProgress}"
                             Maximum="100"
                             IsVisible="{Binding IsDownloadingAppUpdate}"
                             Height="4"/>

                <TextBlock Text="{Binding AppUpdateStatus}"
                           TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>

                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                  <Button Content="{DynamicResource MainWindow.AppUpdateDialog.Button.Download}"
                          Command="{Binding DownloadAppUpdateCommand}"
                          Classes="accent"
                          IsEnabled="{Binding !IsDownloadingAppUpdate}"
                          IsVisible="{Binding !IsDownloadingAppUpdate}"/>
                  <Button Content="{DynamicResource MainWindow.AppUpdateDialog.Button.SilentDownload}"
                          Command="{Binding SilentDownloadAppUpdateCommand}"
                          IsVisible="{Binding IsDownloadingAppUpdate}"/>
                  <Button Content="{DynamicResource MainWindow.AppUpdateDialog.Button.Later}"
                          Command="{Binding CloseStartupUpdateDialogCommand}"
                          IsEnabled="{Binding !IsDownloadingAppUpdate}"
                          IsVisible="{Binding !IsDownloadingAppUpdate}"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </Grid>
        </DataTemplate>
      </ContentControl.ContentTemplate>
    </ContentControl>

    <Grid Grid.Row="0"
          Grid.RowSpan="2"
          IsVisible="{Binding IsInteractionBlocked}"
          Background="#66000000">
      <Border Background="{DynamicResource CartonControlBackgroundChromeMediumBrush}"
              CornerRadius="8"
              Padding="20"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MinWidth="300"
              MaxWidth="420">
        <StackPanel Spacing="12">
          <ProgressBar IsIndeterminate="True"
                       Height="4"/>
          <TextBlock Text="{Binding InteractionBlockedMessage}"
                     TextWrapping="Wrap"
                     TextAlignment="Center"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>

</Window>
