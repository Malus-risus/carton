<UserControl x:Name="ConnectionsViewRoot"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:carton.GUI.Controls"
             xmlns:vm="using:carton.ViewModels"
             mc:Ignorable="d" d:DesignWidth="920" d:DesignHeight="540"
             x:Class="carton.Views.Pages.ConnectionsView"
             x:DataType="vm:ConnectionsViewModel">

  <UserControl.Styles>
    <Style Selector="ListBox.connectionList">
      <Setter Property="Background" Value="{DynamicResource CartonControlBackgroundChromeMediumLowBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="8"/>
    </Style>

    <Style Selector="ListBox.connectionList ListBoxItem">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="ListBox.connectionList ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox.connectionList ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox.connectionList ListBoxItem:selected:pointerover">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox.connectionList ListBoxItem:pressed">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="Border.detailPanel">
      <Setter Property="Background" Value="{DynamicResource CartonControlBackgroundChromeHighBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CartonControlForegroundBaseLowBrush}"/>
      <Setter Property="BorderThickness" Value="1,0,0,0"/>
      <Setter Property="BoxShadow" Value="-8 0 18 0 #26000000"/>
    </Style>

    <Style Selector="Border.detailCard">
      <Setter Property="Background" Value="{DynamicResource CartonSettingsItemBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CartonSettingsItemBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="2,0"/>
    </Style>

    <Style Selector="Border.detailLine">
      <Setter Property="BorderBrush" Value="{DynamicResource CartonSettingsItemBorderBrush}"/>
      <Setter Property="BorderThickness" Value="0,1,0,0"/>
      <Setter Property="Padding" Value="12,9"/>
    </Style>

    <Style Selector="Border.detailLine.first">
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="TextBlock.detailSectionTitle">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style Selector="TextBlock.detailLabel">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
    </Style>

    <Style Selector="TextBlock.detailValue">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="Foreground" Value="{DynamicResource CartonControlForegroundBaseHighBrush}"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">
    <Border Grid.Row="0"
            Background="{DynamicResource CartonControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource CartonControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,10">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
        <Button Grid.Column="0"
                Content="{DynamicResource Connections.Button.CloseAll}"
                Command="{Binding CloseAllCommand}"
                Padding="12,6"/>
        <TextBox Grid.Column="1"
                 Text="{Binding SearchText}"
                 Watermark="{DynamicResource Connections.Search.Watermark}"
                 HorizontalAlignment="Stretch"/>
        <Border Grid.Column="2"
                Classes="fluentBadge"
                VerticalAlignment="Center"
                Padding="10,4">
          <TextBlock Classes="fluentBadgeText" FontSize="12">
            <Run Text="{Binding VisibleConnectionCount}"/>
            <Run Text=" / "/>
            <Run Text="{Binding ConnectionCount}"/>
          </TextBlock>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <ListBox x:Name="ConnectionsListBox"
               Classes="connectionList"
               ItemsSource="{Binding Connections}"
               SelectionChanged="OnConnectionsSelectionChanged">
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel/>
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:ConnectionItemViewModel">
            <controls:ConnectionRowControl HorizontalAlignment="Stretch"/>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <ContentControl Width="380"
                      HorizontalAlignment="Right"
                      Content="{Binding SelectedConnection}"
                      IsVisible="{Binding SelectedConnection, Converter={x:Static ObjectConverters.IsNotNull}}">
        <ContentControl.ContentTemplate>
          <DataTemplate DataType="vm:ConnectionItemViewModel">
            <Border Classes="detailPanel">
              <Grid RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0" Padding="16,14,12,10">
                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <StackPanel Grid.Column="0" Spacing="3">
                      <TextBlock Text="{DynamicResource Connections.Detail.Title}"
                                 FontSize="18"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Id}"
                                 FontFamily="Cascadia Code,Consolas,monospace"
                                 FontSize="11"
                                 Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            Classes="fluentBadge"
                            VerticalAlignment="Center"
                            Padding="8,3"
                            Margin="0,0,8,0">
                      <Grid>
                        <TextBlock Classes="fluentBadgeText"
                                   FontSize="12"
                                   Text="{DynamicResource Connections.Status.Active}"
                                   IsVisible="{Binding IsClosed, Converter={x:Static BoolConverters.Not}}"/>
                        <TextBlock Classes="fluentBadgeText"
                                   FontSize="12"
                                   Text="{DynamicResource Connections.Status.Closed}"
                                   IsVisible="{Binding IsClosed}"/>
                      </Grid>
                    </Border>
                    <Button Grid.Column="2"
                            Width="30"
                            Height="30"
                            Padding="0"
                            Command="{Binding DataContext.ClearSelectedConnectionCommand, ElementName=ConnectionsViewRoot}"
                            ToolTip.Tip="{DynamicResource Connections.Detail.Close}">
                      <PathIcon Width="10" Height="10"
                                Data="M19 6.41L17.59 5L12 10.59L6.41 5L5 6.41L10.59 12L5 17.59L6.41 19L12 13.41L17.59 19L19 17.59L13.41 12L19 6.41Z"/>
                    </Button>
                  </Grid>
                </Border>

                <ScrollViewer Grid.Row="1">
                  <StackPanel Margin="16,0,16,16" Spacing="10">
                    <StackPanel Spacing="8">
                      <TextBlock Classes="detailSectionTitle" Text="{DynamicResource Connections.Detail.Section.Traffic}"/>
                      <Border Classes="detailCard">
                        <StackPanel>
                          <Border Classes="detailLine first">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.CreatedAt}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding StartedAt}"/>
                            </Grid>
                          </Border>
                          <Border Classes="detailLine">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.Uplink}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding Upload}"/>
                            </Grid>
                          </Border>
                          <Border Classes="detailLine">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.Downlink}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding Download}"/>
                            </Grid>
                          </Border>
                        </StackPanel>
                      </Border>
                    </StackPanel>

                    <StackPanel Spacing="8">
                      <TextBlock Classes="detailSectionTitle" Text="{DynamicResource Connections.Detail.Section.Metadata}"/>
                      <Border Classes="detailCard">
                        <StackPanel>
                          <Border Classes="detailLine first">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.Inbound}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding Inbound}"/>
                            </Grid>
                          </Border>
                          <Border Classes="detailLine">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.Network}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding Network}"/>
                            </Grid>
                          </Border>
                          <Border Classes="detailLine">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.Source}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding RawSource}"/>
                            </Grid>
                          </Border>
                          <Border Classes="detailLine">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.Destination}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding RawDestination}"/>
                            </Grid>
                          </Border>
                          <Border Classes="detailLine">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.Domain}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding Domain}"/>
                            </Grid>
                          </Border>
                          <Border Classes="detailLine">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.Protocol}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding Protocol}"/>
                            </Grid>
                          </Border>
                          <Border Classes="detailLine">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.MatchRule}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding MatchRule}"/>
                            </Grid>
                          </Border>
                          <Border Classes="detailLine">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.Outbound}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding Outbound}"/>
                            </Grid>
                          </Border>
                          <Border Classes="detailLine">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.OutboundType}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding OutboundType}"/>
                            </Grid>
                          </Border>
                          <Border Classes="detailLine">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.Chain}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding Chain}"/>
                            </Grid>
                          </Border>
                        </StackPanel>
                      </Border>
                    </StackPanel>

                    <StackPanel Spacing="8"
                                IsVisible="{Binding ProcessDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                      <TextBlock Classes="detailSectionTitle" Text="{DynamicResource Connections.Detail.Section.Process}"/>
                      <Border Classes="detailCard">
                        <StackPanel>
                          <Border Classes="detailLine first">
                            <Grid ColumnDefinitions="104,*">
                              <TextBlock Grid.Column="0" Classes="detailLabel" Text="{DynamicResource Connections.Detail.Process}"/>
                              <TextBlock Grid.Column="1" Classes="detailValue" Text="{Binding ProcessDisplay}"/>
                            </Grid>
                          </Border>
                        </StackPanel>
                      </Border>
                    </StackPanel>
                  </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource CartonControlForegroundBaseLowBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,12">
                  <Button HorizontalAlignment="Stretch"
                          Content="{DynamicResource Connections.Button.Close}"
                          Command="{Binding DataContext.CloseConnectionCommand, ElementName=ConnectionsViewRoot}"
                          CommandParameter="{Binding .}"
                          Padding="12,7"/>
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ContentControl.ContentTemplate>
      </ContentControl>
    </Grid>
  </Grid>

</UserControl>
