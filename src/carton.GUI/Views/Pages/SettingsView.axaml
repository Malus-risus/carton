<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:carton.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="600"
             x:Class="carton.Views.Pages.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer>
    <StackPanel Margin="20" Spacing="16">
      <TextBlock Text="{DynamicResource Settings.Section.Kernel}" FontSize="18" FontWeight="SemiBold"/>

      <Border Classes="card" Padding="16">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Kernel.Version}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding KernelVersion}" 
                       FontWeight="Medium" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
              <Button Content="{DynamicResource Settings.Kernel.CheckUpdate}" Command="{Binding CheckUpdateCommand}"
                      IsEnabled="{Binding CanCheckKernelUpdate}"/>
            </StackPanel>
          </Grid>

          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Kernel.Mirror}" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding KernelDownloadMirrors}"
                      SelectedItem="{Binding SelectedKernelDownloadMirror}"
                      HorizontalAlignment="Left"
                      MinWidth="150">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource KernelDownloadMirrorDisplayConverter}}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>

          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Kernel.CacheCleanupPolicy}" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding KernelCacheCleanupPolicies}"
                      SelectedItem="{Binding SelectedKernelCacheCleanupPolicy}"
                      HorizontalAlignment="Left"
                      MinWidth="200">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource KernelCacheCleanupPolicyDisplayConverter}}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>

          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" IsVisible="{Binding IsKernelInstalled}">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Kernel.Path}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding KernelPath}" 
                       TextTrimming="CharacterEllipsis"
                       FontSize="11"
                       Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
          </Grid>

          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Kernel.Latest}" VerticalAlignment="Center"/>
            <Grid Grid.Column="1">
              <TextBlock Text="{Binding LatestVersion}"
                         VerticalAlignment="Center"
                         IsVisible="{Binding !IsCheckingKernelUpdate}">
                <TextBlock.Transitions>
                  <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
                  </Transitions>
                </TextBlock.Transitions>
              </TextBlock>
              <StackPanel Orientation="Horizontal"
                          Spacing="8"
                          VerticalAlignment="Center"
                          IsVisible="{Binding IsCheckingKernelUpdate}">
                <ProgressBar Width="72"
                             Height="4"
                             IsIndeterminate="True"/>
                <TextBlock Text="{DynamicResource Settings.Kernel.Checking}"
                           Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
              </StackPanel>
            </Grid>
          </Grid>

          <ProgressBar IsIndeterminate="{Binding IsKernelProgressIndeterminate}"
                       Value="{Binding UpdateProgress}"
                       Maximum="100"
                       IsVisible="{Binding IsUpdatingKernel}"
                       Height="4"/>
          
          <TextBlock Text="{Binding UpdateStatus}"
                     IsVisible="{Binding IsUpdatingKernel}"
                     FontSize="12"
                     Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{DynamicResource Settings.Kernel.Update}" Command="{Binding UpdateKernelCommand}"
                    Classes="accent"
                    IsEnabled="{Binding !IsUpdatingKernel}"
                    IsVisible="{Binding IsKernelInstalled}"/>
            <Button Content="{DynamicResource Settings.Kernel.Install}" Command="{Binding UpdateKernelCommand}"
                    Classes="accent"
                    IsEnabled="{Binding !IsUpdatingKernel}"
                    IsVisible="{Binding !IsKernelInstalled}"/>
            <Button Content="{DynamicResource Settings.Kernel.InstallCustom}" Command="{Binding InstallCustomKernelCommand}"
                    IsEnabled="{Binding !IsUpdatingKernel}"/>
            <Button Content="{DynamicResource Settings.Kernel.Uninstall}" Command="{Binding UninstallKernelCommand}"
                    IsEnabled="{Binding CanUninstallKernel}"
                    IsVisible="{Binding IsKernelInstalled}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <TextBlock Text="{DynamicResource Settings.Section.General}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0"/>

      <Border Classes="card" Padding="16">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.General.StartAtLogin}" VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding StartAtLogin}"/>
          </Grid>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" IsEnabled="{Binding StartAtLogin}">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.General.StartHiddenAtLogin}" VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding StartHiddenAtLogin}"/>
          </Grid>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.General.AutoStartOnLaunch}" VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoStartOnLaunch}"/>
          </Grid>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.General.AutoDisconnectConnectionsOnNodeSwitch}" VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoDisconnectConnectionsOnNodeSwitch}"/>
          </Grid>
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="4">
              <TextBlock Text="{DynamicResource Settings.General.RemoteConfigProxy}" VerticalAlignment="Center"/>
              <TextBlock Text="{DynamicResource Settings.General.RemoteConfigProxy.Description}"
                         Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"
                         TextWrapping="Wrap"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding UseProxyForRemoteConfigUpdates}" VerticalAlignment="Top"/>
          </Grid>
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="12"
                IsVisible="{Binding IsWindows}">
            <StackPanel Spacing="4">
              <TextBlock Text="{DynamicResource Settings.General.UwpLoopback.Title}" FontWeight="Medium"/>
              <TextBlock Text="{DynamicResource Settings.General.UwpLoopback.Description}"
                         Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"
                         TextWrapping="Wrap"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="{DynamicResource Settings.General.UwpLoopback.Action}"
                    Command="{Binding OpenLoopbackToolCommand}"
                    IsEnabled="{Binding !IsLoopbackOperationInProgress}"
                    VerticalAlignment="Top"/>
          </Grid>
          <TextBlock Text="{Binding LoopbackStatus}"
                     IsVisible="{Binding HasLoopbackStatus}"
                     Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <TextBlock Text="{DynamicResource Settings.Section.Update}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0"/>

      <Border Classes="card" Padding="16">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Update.Channel}" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding UpdateChannels}"
                      SelectedValue="{Binding SelectedUpdateChannel}"
                      SelectedValueBinding="{Binding Channel}"
                      HorizontalAlignment="Left"
                      MinWidth="150">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding DisplayName}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>

          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Update.AutoCheck}" VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoCheckAppUpdates}"/>
          </Grid>

          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Update.CurrentVersion}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding AppUpdate.CurrentAppVersion}" FontWeight="Medium"/>
          </Grid>

          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Update.LatestVersion}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding AppUpdate.LatestAvailableVersion}" FontWeight="Medium"/>
          </Grid>

          <ProgressBar Maximum="100"
                       Height="4"
                       IsIndeterminate="True"
                       IsVisible="{Binding AppUpdate.IsCheckingAppUpdate}"/>

          <ProgressBar Value="{Binding AppUpdate.AppUpdateProgress}"
                       Maximum="100"
                       Height="4"
                       IsVisible="{Binding AppUpdate.IsDownloadingAppUpdate}"/>

          <TextBlock Text="{Binding AppUpdate.AppUpdateStatus}"
                     Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"
                     TextWrapping="Wrap"/>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{DynamicResource Settings.Update.Check}"
                    Command="{Binding AppUpdate.CheckAppUpdateCommand}"
                    IsEnabled="{Binding !AppUpdate.IsCheckingAppUpdate}"/>
            <Button Content="{DynamicResource Settings.Update.Download}"
                    Command="{Binding AppUpdate.DownloadAppUpdateCommand}"
                    IsEnabled="{Binding AppUpdate.IsAppUpdateAvailable}"
                    IsVisible="{Binding AppUpdate.IsAppUpdateAvailable}"/>
            <Button Content="{DynamicResource Settings.Update.Apply}"
                    Command="{Binding AppUpdate.ApplyAppUpdateCommand}"
                    Classes="accent"
                    IsEnabled="{Binding AppUpdate.IsAppUpdateReadyToInstall}"
                    IsVisible="{Binding AppUpdate.IsAppUpdateReadyToInstall}"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <TextBlock Text="{DynamicResource Settings.Section.Appearance}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0"/>

      <Border Classes="card" Padding="16">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Appearance.Theme}" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Themes}"
                      SelectedValue="{Binding SelectedTheme}"
                      SelectedValueBinding="{Binding Theme}"
                      HorizontalAlignment="Left"
                      MinWidth="150">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding DisplayName}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Appearance.Language}" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage}"
                      HorizontalAlignment="Left"
                      MinWidth="150">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding DisplayName}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </StackPanel>
      </Border>

      <TextBlock Text="{DynamicResource Settings.Section.Data}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0"/>

      <Border Classes="card" Padding="16">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="12"
                IsVisible="{Binding ShowPortableDataOption}">
            <TextBlock Grid.Column="0" Text="{DynamicResource Settings.Data.StoreInAppDir}" VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsDataInExeDirectory}" />
          </Grid>
          <Button Content="{DynamicResource Settings.Data.OpenFolder}" Command="{Binding OpenDataFolderCommand}"
                  HorizontalAlignment="Left"/>
          <Button Content="{DynamicResource Settings.Data.ClearAll}"
                  Command="{Binding ClearAllDataCommand}"
                  IsEnabled="{Binding !IsDataOperationInProgress}"
                  HorizontalAlignment="Left"/>
          <Button Content="{DynamicResource Settings.Data.Backup.Export}" Command="{Binding ExportBackupCommand}"
                  IsEnabled="{Binding !IsDataOperationInProgress}"
                  HorizontalAlignment="Left"/>
          <Button Content="{DynamicResource Settings.Data.Backup.Import}" Command="{Binding ImportBackupCommand}"
                  IsEnabled="{Binding !IsDataOperationInProgress}"
                  HorizontalAlignment="Left"/>
          <Button Content="{DynamicResource Settings.Data.ClearLogs}" Command="{Binding ClearLogsCommand}"
                  HorizontalAlignment="Left"/>
          <Button Content="{DynamicResource Settings.Data.ClearCache}" Command="{Binding ClearCacheCommand}"
                  HorizontalAlignment="Left"/>
          <Button Content="{DynamicResource Settings.Data.Reset}" Command="{Binding ResetSettingsCommand}"
                  HorizontalAlignment="Left"/>
          <TextBlock Text="{Binding DataOperationStatus}"
                     Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <TextBlock Text="{DynamicResource Settings.Section.About}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0"/>

      <Border Classes="card" Padding="16">
        <StackPanel Spacing="8">
          <TextBlock Text="{DynamicResource Settings.About.Name}" FontSize="16" FontWeight="SemiBold"/>
          <TextBlock Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}">
            <TextBlock.Inlines>
              <Run Text="{DynamicResource Settings.About.Version}"/>
              <Run Text=": "/>
              <Run Text="{Binding AppUpdate.CurrentAppVersion}"/>
            </TextBlock.Inlines>
          </TextBlock>
          <TextBlock Text="{DynamicResource Settings.About.Description}" 
                     Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
            <Button Content="{DynamicResource Settings.About.CartonHomepage}"
                    Command="{Binding OpenCartonHomepageCommand}"/>
            <Button Content="{DynamicResource Settings.About.SingBoxHomepage}"
                    Command="{Binding OpenSingBoxHomepageCommand}"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>

</UserControl>
