<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:carton.ViewModels"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="600"
             x:Class="carton.Views.Pages.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.settingsSectionTitle">
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,10,0,6"/>
    </Style>

    <Style Selector="Border.settingsItem">
      <Setter Property="Background" Value="{DynamicResource CartonSettingsItemBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CartonSettingsItemBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="MinHeight" Value="58"/>
    </Style>

    <Style Selector="Border.settingsItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource CartonSettingsItemPointerOverBackgroundBrush}"/>
    </Style>

    <Style Selector="Button.settingsItemLink">
      <Setter Property="Background" Value="{DynamicResource CartonSettingsItemBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CartonSettingsItemBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="MinHeight" Value="58"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Stretch"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter Margin="{TemplateBinding Padding}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                              Content="{TemplateBinding Content}"/>
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="Button.settingsItemLink:pointerover">
      <Setter Property="Background" Value="{DynamicResource CartonSettingsItemPointerOverBackgroundBrush}"/>
    </Style>

    <Style Selector="TextBlock.settingsTitle">
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.settingsDescription">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{DynamicResource CartonControlForegroundBaseMediumBrush}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="ComboBox.settingsAction">
      <Setter Property="MinWidth" Value="160"/>
    </Style>

    <Style Selector="Button.accentColorButton">
      <Setter Property="Width" Value="42"/>
      <Setter Property="Height" Value="42"/>
      <Setter Property="MinWidth" Value="0"/>
      <Setter Property="MinHeight" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="1"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Styles>
      <Styles.Resources>
        <ControlTheme x:Key="SettingsTabStripTheme" TargetType="TabStrip">
      <Setter Property="MinHeight" Value="32"/>
      <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
      <Setter Property="Background" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="IsTabStop" Value="False"/>
      <Setter Property="KeyboardNavigation.TabNavigation" Value="Once"/>
      <Setter Property="Padding" Value="-1"/>
      <Setter Property="ItemsPanel">
        <ItemsPanelTemplate>
          <WrapPanel/>
        </ItemsPanelTemplate>
      </Setter>
      <Setter Property="Template">
        <ControlTemplate>
          <Border Height="{TemplateBinding Height}"
                  VerticalAlignment="Stretch"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <ItemsPresenter Margin="{TemplateBinding Padding}"
                            VerticalAlignment="Stretch"
                            ItemsPanel="{TemplateBinding ItemsPanel}"/>
          </Border>
        </ControlTemplate>
      </Setter>
    </ControlTheme>

    <ControlTheme x:Key="SettingsTabItemTheme" TargetType="TabStripItem">
      <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="FontFamily" Value="{DynamicResource ContentControlThemeFontFamily}"/>
      <Setter Property="Background" Value="{DynamicResource ControlFillColorTransparentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ControlFillColorTransparentBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
      <Setter Property="FontWeight" Value="Normal"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="MinWidth" Value="32"/>
      <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Border Name="Root"
                  VerticalAlignment="{TemplateBinding VerticalAlignment}"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  TemplatedControl.IsTemplateFocusTarget="True">
            <Border.Transitions>
              <Transitions>
                <BrushTransition Property="Background" Duration="00:00:00.083"/>
              </Transitions>
            </Border.Transitions>

            <Panel>
              <Border Name="Hover"
                      Margin="3"
                      Background="Transparent"
                      CornerRadius="{TemplateBinding CornerRadius}">
                <Border.Transitions>
                  <Transitions>
                    <BrushTransition Property="Background" Duration="00:00:00.083"/>
                    <TransformOperationsTransition Easing="0,0 0,1"
                                                   Property="RenderTransform"
                                                   Duration="00:00:00.167"/>
                  </Transitions>
                </Border.Transitions>
              </Border>

              <ContentPresenter Name="PART_ContentPresenter"
                                Margin="11,5,11,6"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Content="{TemplateBinding Content}"
                                FontWeight="{TemplateBinding FontWeight}"
                                Foreground="{TemplateBinding Foreground}"/>

              <Rectangle Name="Pill"
                         Width="4"
                         Height="3"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Bottom"
                         Fill="{DynamicResource AccentFillColorDefaultBrush}"
                         Opacity="0"
                         RadiusX="0.5"
                         RadiusY="1"
                         RenderTransform="scaleX(4)">
                <Rectangle.Transitions>
                  <Transitions>
                    <TransformOperationsTransition Easing="0,0 0,1"
                                                   Property="RenderTransform"
                                                   Duration="00:00:00.167"/>
                  </Transitions>
                </Rectangle.Transitions>
              </Rectangle>
            </Panel>
          </Border>
        </ControlTemplate>
      </Setter>

      <Style Selector="^:pointerover">
        <Style Selector="^ /template/ Border#Hover">
          <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
        </Style>
      </Style>

      <Style Selector="^:pressed">
        <Style Selector="^ /template/ Border#Hover">
          <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
          <Setter Property="RenderTransform" Value="scale(0.96)"/>
        </Style>
        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
          <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
        </Style>
      </Style>

      <Style Selector="^:selected">
        <Style Selector="^ /template/ Border#Hover">
          <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="^ /template/ Border#Root">
          <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
        </Style>
        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
          <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
        <Style Selector="^ /template/ Rectangle#Pill">
          <Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="^:pressed /template/ Rectangle#Pill">
          <Setter Property="RenderTransform" Value="scaleX(1)"/>
        </Style>
      </Style>

      <Style Selector="^:disabled">
        <Style Selector="^ /template/ Border#Hover">
          <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="^ /template/ Border#Root">
          <Setter Property="Background" Value="{DynamicResource ControlFillColorDisabledBrush}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource ControlAltFillColorSecondaryBrush}"/>
        </Style>
        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
          <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>
        </Style>
      </Style>
    </ControlTheme>
      </Styles.Resources>
    </Styles>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">
    <TabStrip Name="SettingsTabStrip"
              Grid.Row="0"
              Theme="{StaticResource SettingsTabStripTheme}"
              ItemContainerTheme="{StaticResource SettingsTabItemTheme}"
              Margin="0,8,20,0"
              HorizontalAlignment="Right">
      <TabStripItem Content="{DynamicResource Settings.Section.Kernel}" Tag="SectionKernel"/>
      <TabStripItem Content="{DynamicResource Settings.Section.Interface}" Tag="SectionInterface"/>
      <TabStripItem Content="{DynamicResource Settings.Section.General}" Tag="SectionGeneral"/>
      <TabStripItem Content="{DynamicResource Settings.Section.Update}" Tag="SectionUpdate"/>
      <TabStripItem Content="{DynamicResource Settings.Section.Data}" Tag="SectionData"/>
      <TabStripItem Content="{DynamicResource Settings.Section.About}" Tag="SectionAbout"/>
    </TabStrip>

    <ScrollViewer Grid.Row="1" Name="SettingsScrollViewer">
    <StackPanel Margin="20" Spacing="8">
      <StackPanel x:Name="SectionKernel">
      <TextBlock Classes="settingsSectionTitle" Text="{DynamicResource Settings.Section.Kernel}"/>

      <StackPanel Spacing="6">
        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="3" VerticalAlignment="Center">
              <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.Kernel.Version}"/>
              <TextBlock Classes="settingsDescription" Text="{Binding KernelVersion}"/>
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
              <Grid VerticalAlignment="Center" MinWidth="92">
                <StackPanel Spacing="3" IsVisible="{Binding !IsCheckingKernelUpdate}">
                  <TextBlock Classes="settingsTitle"
                             Text="{DynamicResource Settings.Kernel.Latest}"
                             HorizontalAlignment="Right"/>
                  <TextBlock Classes="settingsDescription"
                             Text="{Binding LatestVersion}"
                             HorizontalAlignment="Right"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            IsVisible="{Binding IsCheckingKernelUpdate}">
                  <ProgressBar Width="72" Height="4" IsIndeterminate="True" VerticalAlignment="Center"/>
                  <TextBlock Classes="settingsDescription"
                             Text="{DynamicResource Settings.Kernel.Checking}"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Grid>
              <Button Content="{DynamicResource Settings.Kernel.CheckUpdate}"
                      Command="{Binding CheckUpdateCommand}"
                      IsEnabled="{Binding CanCheckKernelUpdate}"
                      VerticalAlignment="Center"/>
            </StackPanel>
          </Grid>
        </Border>

        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.Kernel.Mirror}"/>
            <ComboBox Grid.Column="1"
                      Classes="settingsAction"
                      ItemsSource="{Binding KernelDownloadMirrors}"
                      SelectedItem="{Binding SelectedKernelDownloadMirror}"
                      VerticalAlignment="Center">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource KernelDownloadMirrorDisplayConverter}}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </Border>

        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.Kernel.CacheCleanupPolicy}"/>
            <ComboBox Grid.Column="1"
                      Classes="settingsAction"
                      MinWidth="220"
                      ItemsSource="{Binding KernelCacheCleanupPolicies}"
                      SelectedItem="{Binding SelectedKernelCacheCleanupPolicy}"
                      VerticalAlignment="Center">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource KernelCacheCleanupPolicyDisplayConverter}}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </Border>

        <Button Classes="settingsItemLink"
                Command="{Binding OpenKernelFolderCommand}"
                IsVisible="{Binding IsKernelInstalled}"
                ToolTip.Tip="{DynamicResource Settings.Data.OpenFolder}">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="3">
              <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.Kernel.Path}"/>
              <TextBlock Classes="settingsDescription"
                         Text="{Binding KernelPath}"
                         TextTrimming="CharacterEllipsis"
                         MaxLines="1"/>
            </StackPanel>
            <TextBlock Grid.Column="1"
                       Text="&#xE838;"
                       FontFamily="Segoe Fluent Icons"
                       FontSize="16"
                       Foreground="{DynamicResource CartonControlForegroundBaseMediumBrush}"
                       VerticalAlignment="Center"/>
          </Grid>
        </Button>

        <Border Classes="settingsItem" IsVisible="{Binding IsUpdatingKernel}">
          <StackPanel Spacing="8">
            <ProgressBar IsIndeterminate="{Binding IsKernelProgressIndeterminate}"
                         Value="{Binding UpdateProgress}"
                         Maximum="100"
                         Height="4"/>
            <TextBlock Classes="settingsDescription" Text="{Binding UpdateStatus}"/>
          </StackPanel>
        </Border>

        <Border Classes="settingsItem">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{DynamicResource Settings.Kernel.Update}"
                    Command="{Binding UpdateKernelCommand}"
                    Classes="accent"
                    IsEnabled="{Binding !IsUpdatingKernel}"
                    IsVisible="{Binding IsKernelInstalled}"/>
            <Button Content="{DynamicResource Settings.Kernel.Install}"
                    Command="{Binding UpdateKernelCommand}"
                    Classes="accent"
                    IsEnabled="{Binding !IsUpdatingKernel}"
                    IsVisible="{Binding !IsKernelInstalled}"/>
            <Button Content="{DynamicResource Settings.Kernel.InstallCustom}"
                    Command="{Binding InstallCustomKernelCommand}"
                    IsEnabled="{Binding !IsUpdatingKernel}"/>
            <Button Content="{DynamicResource Settings.Kernel.Uninstall}"
                    Command="{Binding UninstallKernelCommand}"
                    IsEnabled="{Binding CanUninstallKernel}"
                    IsVisible="{Binding IsKernelInstalled}"/>
          </StackPanel>
        </Border>
      </StackPanel>
      </StackPanel>

      <StackPanel x:Name="SectionInterface">
      <TextBlock Classes="settingsSectionTitle" Text="{DynamicResource Settings.Section.Interface}"/>

      <StackPanel Spacing="6">
        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.Appearance.Theme}"/>
            <ComboBox Grid.Column="1"
                      Classes="settingsAction"
                      ItemsSource="{Binding Themes}"
                      SelectedValue="{Binding SelectedTheme}"
                      SelectedValueBinding="{Binding Theme}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding DisplayName}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </Border>
        <ui:SettingsExpander Header="{DynamicResource Settings.Appearance.ThemeAccent}"
                             Description="{DynamicResource Settings.Appearance.ThemeAccent.Description}"
                             IsExpanded="{Binding IsThemeAccentExpanded, Mode=TwoWay}">
          <ui:SettingsExpander.IconSource>
            <ui:FontIconSource FontFamily="Segoe Fluent Icons" Glyph="&#xE790;" />
          </ui:SettingsExpander.IconSource>
          <ui:SettingsExpander.Footer>
            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center">
              <RadioButton Content="{DynamicResource Settings.Appearance.ThemeAccent.SystemDefault}"
                           GroupName="ThemeAccentMode"
                           IsChecked="{Binding UseSystemThemeAccent, Mode=OneWay}"
                           Click="OnUseSystemThemeAccentClick"
                           Tag="System"/>
              <RadioButton Content="{DynamicResource Settings.Appearance.ThemeAccent.Custom}"
                           GroupName="ThemeAccentMode"
                           IsChecked="{Binding UseCustomThemeAccent, Mode=OneWay}"
                           Click="OnUseCustomThemeAccentClick"
                           Tag="Custom"/>
            </StackPanel>
          </ui:SettingsExpander.Footer>

          <ui:SettingsExpanderItem IsClickEnabled="False">
            <ui:SettingsExpanderItem.Content>
              <ContentControl Content="{Binding ThemeAccentContent}">
                <ContentControl.ContentTemplate>
                  <DataTemplate DataType="vm:SettingsViewModel">
                    <StackPanel Spacing="0" Margin="0,4,0,0">
                      <DockPanel LastChildFill="False" Margin="36,6,0,8">
                        <TextBlock DockPanel.Dock="Left"
                                   Classes="settingsTitle"
                                   Text="{DynamicResource Settings.Appearance.ThemeAccent.PreviewColor}"
                                   VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Spacing="4">
                          <Border Width="180"
                                  Height="32"
                                  CornerRadius="4"
                                  ClipToBounds="True">
                            <Grid ColumnDefinitions="*,*,*,*,*">
                              <Border Grid.Column="0" Background="{DynamicResource SystemAccentColorLight3}"/>
                              <Border Grid.Column="1" Background="{DynamicResource SystemAccentColorLight1}" Margin="1,0,0,0"/>
                              <Border Grid.Column="2" Background="{DynamicResource SystemAccentColor}" Margin="1,0,0,0"/>
                              <Border Grid.Column="3" Background="{DynamicResource SystemAccentColorDark1}" Margin="1,0,0,0"/>
                              <Border Grid.Column="4" Background="{DynamicResource SystemAccentColorDark3}" Margin="1,0,0,0"/>
                            </Grid>
                          </Border>
                          <TextBlock Classes="settingsDescription"
                                     Text="{Binding ThemeAccentSourceDisplay}"
                                     HorizontalAlignment="Right"/>
                        </StackPanel>
                      </DockPanel>

                      <Border Background="{DynamicResource CartonControlBackgroundBaseLowBrush}"
                              Height="1"
                              Margin="-16,8,-16,0"/>

                      <TextBlock Margin="36,24,0,0"
                                 Classes="settingsTitle"
                                 Text="{DynamicResource Settings.Appearance.ThemeAccent.WindowsColors}"/>
                      <ItemsControl HorizontalAlignment="Left"
                                    Margin="36,0,24,12"
                                    MaxWidth="360"
                                    ItemsSource="{Binding ThemeAccentColors}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <WrapPanel/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate DataType="vm:AccentColorOptionViewModel">
                            <Button Classes="accentColorButton"
                                    Command="{Binding $parent[UserControl].DataContext.SelectThemeAccentColorCommand}"
                                    CommandParameter="{Binding}">
                              <Panel Width="42" Height="42">
                                <Border Background="{Binding Brush}"
                                        BorderBrush="{DynamicResource CartonControlForegroundBaseMediumLowBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Width="42"
                                        Height="42"/>
                                <Border Background="{DynamicResource CartonControlBackgroundChromeHighBrush}"
                                        Width="18"
                                        Height="18"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,2,2,0"
                                        IsVisible="{Binding IsSelected}">
                                  <TextBlock Text="&#xE73E;"
                                             FontFamily="Segoe Fluent Icons"
                                             FontSize="12"
                                             Foreground="{DynamicResource SystemAccentColor}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                </Border>
                              </Panel>
                            </Button>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>

                      <Border Background="{DynamicResource CartonControlBackgroundBaseLowBrush}"
                              Height="1"
                              Margin="-16,0,-16,0"/>

                      <Grid ColumnDefinitions="Auto,*"
                            ColumnSpacing="24"
                            Margin="36,12,0,0">
                        <TextBlock Classes="settingsTitle"
                                   Text="{DynamicResource Settings.Appearance.ThemeAccent.CustomColor}"
                                   VerticalAlignment="Center"/>
                        <ColorPicker Grid.Column="1"
                                     Color="{Binding SelectedThemeAccentColor, Mode=TwoWay}"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Center"/>
                      </Grid>
                    </StackPanel>
                  </DataTemplate>
                </ContentControl.ContentTemplate>
              </ContentControl>
            </ui:SettingsExpanderItem.Content>
          </ui:SettingsExpanderItem>
        </ui:SettingsExpander>
        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.Appearance.Language}"/>
            <ComboBox Grid.Column="1"
                      Classes="settingsAction"
                      ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding DisplayName}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </Border>
        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="3">
              <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.General.SaveWindowPlacement}"/>
              <TextBlock Classes="settingsDescription" Text="{DynamicResource Settings.General.SaveWindowPlacement.Description}"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding SaveWindowPlacement}" VerticalAlignment="Center"/>
          </Grid>
        </Border>
      </StackPanel>
      </StackPanel>

      <StackPanel x:Name="SectionGeneral">
      <TextBlock Classes="settingsSectionTitle" Text="{DynamicResource Settings.Section.General}"/>

      <StackPanel Spacing="6">
        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.General.StartAtLogin}"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding StartAtLogin}"/>
          </Grid>
        </Border>
        <Border Classes="settingsItem" IsEnabled="{Binding StartAtLogin}">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.General.StartHiddenAtLogin}"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding StartHiddenAtLogin}"/>
          </Grid>
        </Border>
        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.General.AutoStartOnLaunch}"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoStartOnLaunch}"/>
          </Grid>
        </Border>
        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.General.AutoDisconnectConnectionsOnNodeSwitch}"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoDisconnectConnectionsOnNodeSwitch}"/>
          </Grid>
        </Border>
        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="3">
              <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.General.GitHubUpdateCheckStrategy}"/>
              <TextBlock Classes="settingsDescription" Text="{DynamicResource Settings.General.GitHubUpdateCheckStrategy.Description}"/>
            </StackPanel>
            <ComboBox Grid.Column="1"
                      Classes="settingsAction"
                      MinWidth="220"
                      ItemsSource="{Binding GitHubUpdateCheckStrategies}"
                      SelectedItem="{Binding SelectedGitHubUpdateCheckStrategy}"
                      VerticalAlignment="Center">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={StaticResource GitHubUpdateCheckStrategyDisplayConverter}}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </Border>
        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="3">
              <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.General.RemoteConfigProxy}"/>
              <TextBlock Classes="settingsDescription" Text="{DynamicResource Settings.General.RemoteConfigProxy.Description}"/>
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding UseProxyForRemoteConfigUpdates}" VerticalAlignment="Center"/>
          </Grid>
        </Border>
        <Border Classes="settingsItem">
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Spacing="3">
                <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.General.CustomUserAgent}"/>
                <TextBlock Classes="settingsDescription" Text="{DynamicResource Settings.General.CustomUserAgent.Description}"/>
              </StackPanel>
              <ToggleSwitch Grid.Column="1" IsChecked="{Binding CustomUserAgentEnabled}" VerticalAlignment="Center"/>
            </Grid>
            <TextBox Text="{Binding CustomUserAgent, UpdateSourceTrigger=LostFocus}"
                     IsVisible="{Binding CustomUserAgentEnabled}"
                     Watermark="User-Agent"
                     Margin="0,4,0,0"/>
          </StackPanel>
        </Border>
        <Border Classes="settingsItem" IsVisible="{Binding IsWindows}">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="3">
              <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.General.UwpLoopback.Title}"/>
              <TextBlock Classes="settingsDescription" Text="{DynamicResource Settings.General.UwpLoopback.Description}"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="{DynamicResource Settings.General.UwpLoopback.Action}"
                    Command="{Binding OpenLoopbackToolCommand}"
                    IsEnabled="{Binding !IsLoopbackOperationInProgress}"
                    VerticalAlignment="Center"/>
          </Grid>
        </Border>
        <TextBlock Classes="settingsDescription"
                   Text="{Binding LoopbackStatus}"
                   IsVisible="{Binding HasLoopbackStatus}"
                   Margin="16,4"/>
        <Border Classes="settingsItem" IsVisible="{Binding IsWindows}">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="3">
              <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.General.ElevatedTask.Title}"/>
              <TextBlock Classes="settingsDescription" Text="{DynamicResource Settings.General.ElevatedTask.Description}"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="{DynamicResource Settings.General.ElevatedTask.Action}"
                    Command="{Binding RepairElevatedTaskCommand}"
                    IsEnabled="{Binding !IsElevatedTaskOperationInProgress}"
                    VerticalAlignment="Center"/>
          </Grid>
        </Border>
        <TextBlock Classes="settingsDescription"
                   Text="{Binding ElevatedTaskStatus}"
                   IsVisible="{Binding HasElevatedTaskStatus}"
                   Margin="16,4"
                   TextWrapping="Wrap"/>
      </StackPanel>
      </StackPanel>

      <StackPanel x:Name="SectionUpdate">
      <TextBlock Classes="settingsSectionTitle" Text="{DynamicResource Settings.Section.Update}"/>

      <StackPanel Spacing="6">
        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.Update.Channel}"/>
            <ComboBox Grid.Column="1"
                      Classes="settingsAction"
                      ItemsSource="{Binding UpdateChannels}"
                      SelectedValue="{Binding SelectedUpdateChannel}"
                      SelectedValueBinding="{Binding Channel}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding DisplayName}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </Border>
        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.Update.AutoCheck}"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoCheckAppUpdates}"/>
          </Grid>
        </Border>
        <Border Classes="settingsItem">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="3" VerticalAlignment="Center">
              <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.Update.CurrentVersion}"/>
              <TextBlock Classes="settingsDescription" Text="{Binding AppUpdate.CurrentAppVersion}"/>
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center">
              <StackPanel Spacing="3" MinWidth="92">
                <TextBlock Classes="settingsTitle"
                           Text="{DynamicResource Settings.Update.LatestVersion}"
                           HorizontalAlignment="Right"/>
                <TextBlock Classes="settingsDescription"
                           Text="{Binding AppUpdate.LatestAvailableVersionDisplay}"
                           HorizontalAlignment="Right"/>
              </StackPanel>
              <Button Content="{DynamicResource Settings.Update.Check}"
                      Command="{Binding AppUpdate.CheckAppUpdateCommand}"
                      IsEnabled="{Binding !AppUpdate.IsCheckingAppUpdate}"/>
              <Button Content="{DynamicResource Settings.Update.Download}"
                      Command="{Binding AppUpdate.DownloadAppUpdateCommand}"
                      IsEnabled="{Binding AppUpdate.IsAppUpdateAvailable}"
                      IsVisible="{Binding AppUpdate.IsAppUpdateAvailable}"/>
              <Button Content="{DynamicResource Settings.Update.Apply}"
                      Command="{Binding AppUpdate.ApplyAppUpdateCommand}"
                      Classes="accent"
                      IsEnabled="{Binding AppUpdate.IsAppUpdateReadyToInstall}"
                      IsVisible="{Binding AppUpdate.IsAppUpdateReadyToInstall}"/>
            </StackPanel>
          </Grid>
        </Border>
        <Border Classes="settingsItem" IsVisible="{Binding AppUpdate.IsCheckingAppUpdate}">
          <ProgressBar Maximum="100" Height="4" IsIndeterminate="True"/>
        </Border>
        <Border Classes="settingsItem" IsVisible="{Binding AppUpdate.IsDownloadingAppUpdate}">
          <ProgressBar Value="{Binding AppUpdate.AppUpdateProgress}" Maximum="100" Height="4"/>
        </Border>
        <TextBlock Classes="settingsDescription"
                   Text="{Binding AppUpdate.AppUpdateStatus}"
                   IsVisible="{Binding AppUpdate.ShouldShowAppUpdateStatus}"
                   Margin="16,4"/>
      </StackPanel>
      </StackPanel>

      <StackPanel x:Name="SectionData">
      <TextBlock Classes="settingsSectionTitle" Text="{DynamicResource Settings.Section.Data}"/>

      <StackPanel Spacing="6">
        <Border Classes="settingsItem" IsVisible="{Binding ShowPortableDataOption}">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.Data.StoreInAppDir}"/>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsDataInExeDirectory}"/>
          </Grid>
        </Border>

        <ui:SettingsExpander Header="{DynamicResource Settings.Data.Directory}"
                             IsExpanded="False">
          <ui:SettingsExpander.IconSource>
            <ui:FontIconSource FontFamily="Segoe Fluent Icons" Glyph="&#xE7F1;" />
          </ui:SettingsExpander.IconSource>

          <ui:SettingsExpanderItem ActionIconSource="Open"
                                   Command="{Binding OpenDataFolderCommand}"
                                   IsClickEnabled="True"
                                   ToolTip.Tip="{DynamicResource Settings.Data.OpenFolder}">
            <ui:SettingsExpanderItem.Content>
              <StackPanel Spacing="3">
                <TextBlock Classes="settingsTitle" Text="{DynamicResource Settings.Data.OpenFolder}"/>
                <TextBlock Classes="settingsDescription"
                           Text="{Binding DataDirectoryPath}"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"/>
              </StackPanel>
            </ui:SettingsExpanderItem.Content>
          </ui:SettingsExpanderItem>

          <ui:SettingsExpanderItem Content="{DynamicResource Settings.Data.Cleanup}"
                                   IsClickEnabled="False">
            <ui:SettingsExpanderItem.Footer>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="{DynamicResource Settings.Data.ClearAll}"
                        Command="{Binding ClearAllDataCommand}"
                        IsEnabled="{Binding !IsDataOperationInProgress}"/>
                <Button Content="{DynamicResource Settings.Data.ClearLogs}"
                        Command="{Binding ClearLogsCommand}"/>
                <Button Content="{DynamicResource Settings.Data.ClearCache}"
                        Command="{Binding ClearCacheCommand}"/>
              </StackPanel>
            </ui:SettingsExpanderItem.Footer>
          </ui:SettingsExpanderItem>
        </ui:SettingsExpander>
        <TextBlock Classes="settingsDescription"
                   Text="{Binding DataOperationStatus}"
                   IsVisible="{Binding HasDataOperationStatus}"
                   Margin="16,4"
                   TextWrapping="Wrap"/>

        <Border Classes="settingsItem">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="{DynamicResource Settings.Data.Backup.Export}"
                    Command="{Binding ExportBackupCommand}"
                    IsEnabled="{Binding !IsDataOperationInProgress}"/>
            <Button Content="{DynamicResource Settings.Data.Backup.Import}"
                    Command="{Binding ImportBackupCommand}"
                    IsEnabled="{Binding !IsDataOperationInProgress}"/>
            <Button Content="{DynamicResource Settings.Data.Reset}"
                    Command="{Binding ResetSettingsCommand}"/>
          </StackPanel>
        </Border>
      </StackPanel>
      </StackPanel>

      <StackPanel x:Name="SectionAbout">
      <TextBlock Classes="settingsSectionTitle" Text="{DynamicResource Settings.Section.About}"/>

      <StackPanel Spacing="6" Margin="0,0,0,12">
        <Border Classes="settingsItem">
          <StackPanel Spacing="6">
            <TextBlock Text="{DynamicResource Settings.About.Name}" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock Classes="settingsDescription">
              <TextBlock.Inlines>
                <Run Text="{DynamicResource Settings.About.Version}"/>
                <Run Text=": "/>
                <Run Text="{Binding AppUpdate.CurrentAppVersion}"/>
              </TextBlock.Inlines>
            </TextBlock>
            <TextBlock Classes="settingsDescription" Text="{DynamicResource Settings.About.Description}"/>
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
              <Button Command="{Binding OpenCartonHomepageCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Width="14"
                            Height="14"
                            Data="M8 0 C3.58 0 0 3.58 0 8 C0 11.54 2.29 14.53 5.47 15.59 C5.87 15.66 6.02 15.42 6.02 15.21 C6.02 15.02 6.01 14.39 6.01 13.72 C4 14.09 3.48 13.23 3.32 12.78 C3.23 12.55 2.84 11.84 2.5 11.65 C2.22 11.5 1.82 11.13 2.49 11.12 C3.12 11.11 3.57 11.7 3.72 11.94 C4.44 13.15 5.59 12.81 6.05 12.6 C6.12 12.08 6.33 11.73 6.56 11.53 C4.78 11.33 2.92 10.64 2.92 7.58 C2.92 6.71 3.23 5.99 3.74 5.43 C3.66 5.23 3.38 4.41 3.82 3.31 C3.82 3.31 4.49 3.1 6.02 4.13 C6.66 3.95 7.34 3.86 8.02 3.86 C8.7 3.86 9.38 3.95 10.02 4.13 C11.55 3.09 12.22 3.31 12.22 3.31 C12.66 4.41 12.38 5.23 12.3 5.43 C12.81 5.99 13.12 6.7 13.12 7.58 C13.12 10.65 11.25 11.33 9.47 11.53 C9.76 11.78 10.01 12.26 10.01 13.01 C10.01 14.08 10 14.94 10 15.21 C10 15.42 10.15 15.67 10.55 15.59 C13.71 14.53 16 11.53 16 8 C16 3.58 12.42 0 8 0 Z"/>
                  <TextBlock Text="{DynamicResource Settings.About.CartonHomepage}"/>
                </StackPanel>
              </Button>
              <Button Command="{Binding OpenTelegramGroupCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Viewbox Width="14" Height="14">
                    <Canvas Width="240" Height="240">
                      <Ellipse Width="240" Height="240">
                        <Ellipse.Fill>
                          <LinearGradientBrush StartPoint="50%,100%" EndPoint="50%,0%">
                            <GradientStop Color="#1D93D2" Offset="0"/>
                            <GradientStop Color="#38B0E3" Offset="1"/>
                          </LinearGradientBrush>
                        </Ellipse.Fill>
                      </Ellipse>
                      <Path Fill="#C8DAEA"
                            Data="M81.229 128.772l14.237 39.406s1.78 3.687 3.686 3.687 30.255-29.492 30.255-29.492l31.525-60.89L81.737 118.6Z"/>
                      <Path Fill="#A9C6D8"
                            Data="M100.106 138.878l-2.733 29.046s-1.144 8.9 7.754 0 17.415-15.763 17.415-15.763"/>
                      <Path Fill="White"
                            Data="M81.486 130.178L52.2 120.636s-3.5-1.42-2.373-4.64c.232-.664.7-1.229 2.1-2.2 6.489-4.523 120.106-45.36 120.106-45.36s3.208-1.081 5.1-.362a2.766 2.766 0 0 1 1.885 2.055 9.357 9.357 0 0 1 .254 2.585c-.009.752-.1 1.449-.169 2.542-.692 11.165-21.4 94.493-21.4 94.493s-1.239 4.876-5.678 5.043A8.13 8.13 0 0 1 146.1 172.5c-8.711-7.493-38.819-27.727-45.472-32.177a1.27 1.27 0 0 1-.546-.9c-.093-.469.417-1.05.417-1.05s52.426-46.6 53.821-51.492c.108-.379-.3-.566-.848-.4-3.482 1.281-63.844 39.4-70.506 43.607a3.21 3.21 0 0 1-1.48.09Z"/>
                    </Canvas>
                  </Viewbox>
                  <TextBlock Text="{DynamicResource Settings.About.TelegramGroup}"/>
                </StackPanel>
              </Button>
              <Button Command="{Binding OpenSingBoxHomepageCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <PathIcon Width="14"
                            Height="14"
                            Data="M8 0 C3.58 0 0 3.58 0 8 C0 11.54 2.29 14.53 5.47 15.59 C5.87 15.66 6.02 15.42 6.02 15.21 C6.02 15.02 6.01 14.39 6.01 13.72 C4 14.09 3.48 13.23 3.32 12.78 C3.23 12.55 2.84 11.84 2.5 11.65 C2.22 11.5 1.82 11.13 2.49 11.12 C3.12 11.11 3.57 11.7 3.72 11.94 C4.44 13.15 5.59 12.81 6.05 12.6 C6.12 12.08 6.33 11.73 6.56 11.53 C4.78 11.33 2.92 10.64 2.92 7.58 C2.92 6.71 3.23 5.99 3.74 5.43 C3.66 5.23 3.38 4.41 3.82 3.31 C3.82 3.31 4.49 3.1 6.02 4.13 C6.66 3.95 7.34 3.86 8.02 3.86 C8.7 3.86 9.38 3.95 10.02 4.13 C11.55 3.09 12.22 3.31 12.22 3.31 C12.66 4.41 12.38 5.23 12.3 5.43 C12.81 5.99 13.12 6.7 13.12 7.58 C13.12 10.65 11.25 11.33 9.47 11.53 C9.76 11.78 10.01 12.26 10.01 13.01 C10.01 14.08 10 14.94 10 15.21 C10 15.42 10.15 15.67 10.55 15.59 C13.71 14.53 16 11.53 16 8 C16 3.58 12.42 0 8 0 Z"/>
                  <TextBlock Text="{DynamicResource Settings.About.SingBoxHomepage}"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
      </StackPanel>
    </StackPanel>
    </ScrollViewer>
  </Grid>

</UserControl>
